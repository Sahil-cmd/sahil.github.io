{
  "name": "sahilpanjwani-portfolio",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npx @11ty/eleventy",
    "serve": "npx @11ty/eleventy --serve",
    "check:html": "npx html-validate '_site/**/*.html'",
    "check:css": "npx stylelint 'src/css/**/*.css'",
    "check:format": "npx prettier --check 'src/**/*.{css,json}' '*.json' '.github/workflows/*.yml' 'eleventy.config.js'",
    "check:a11y": "npx @11ty/eleventy --serve --port=8888 & sleep 5 && npx pa11y-ci http://localhost:8888/ http://localhost:8888/case-studies/sensorsphere/ ; kill %1"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "html-validate": "^10.9.0",
    "pa11y-ci": "^4.0.1",
    "prettier": "^3.8.1",
    "stylelint": "^17.3.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
